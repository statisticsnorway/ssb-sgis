-myst-parser = { version = ">=0.16.1" }
+[project.scripts]
+ssb-sgis = "sgis.__main__:main"
+
+[dependency-groups]
+lint = [
+    "black[jupyter]>=25.11.0",
+    "pre-commit>=4.4.0",
+    "pre-commit-hooks>=6.0.0",
+    "pydoclint>=0.8.3",
+    "ruff>=0.14.5",
+]
+doc = [
+    "furo>=2025.9.25",
+    "myst-parser>=4.0.1",
+    "sphinx>=8.2.3",
+    "sphinx-autobuild>=2025.8.25",
+    "sphinx-autodoc-typehints>=3.5.2",
+    "sphinx-click>=6.1.0",
+]
+
+# Type hint stubs should be placed in the dev dependency group
+dev = [
+    {include-group = "lint"},
+    {include-group = "doc"},
+    "coverage[toml]>=7.11.3",
+    "deptry>=0.24.0; python_version < '4.0'",
+    "mypy>=1.18.2",
+    "pygments>=2.19.0",
+    "pytest>=9.0.0",
+    "typeguard>=2.13.3",
+    "xdoctest[colors]>=1.3.0",
+]
+
+[tool.poetry]
+classifiers = ["Development Status :: 5 - Production/Stable"]
+requires-poetry = ">=2.3"
+packages = [{ include = "sgis", from = "src" }]
+
+[tool.poetry.requires-plugins]
+poetry-plugin-export = ">=1.9"

 [tool.pytest.ini_options]
 pythonpath = ["src"]

-[tool.poetry.scripts]
-ssb-sgis = "sgis.__main__:main"
-
 [tool.coverage.paths]
 source = ["src", "*/site-packages"]
 tests = ["tests", "*/tests"]
@@ -56,6 +74,9 @@ relative_files = true
 show_missing = true
