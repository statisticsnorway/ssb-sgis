-[tool.poetry.urls]
 Changelog = "https://github.com/statisticsnorway/ssb-sgis/releases"

-[tool.poetry.dependencies]
-python = "^3.10"
-click = ">=8.0.1"
-
-[tool.poetry.group.dev.dependencies]
